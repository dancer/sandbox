{
  "name": "@sandbox-sdk/cloudflare",
  "version": "0.0.0",
  "description": "Cloudflare Sandbox adapter for Sandbox SDK",
  "keywords": [
    "agent",
    "cloudflare",
    "sandbox",
    "sdk",
    "typescript",
    "workers"
  ],
  "homepage": "https://sandbox-sdk.sh",
  "bugs": {
    "url": "https://github.com/dancer/sandbox/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dancer/sandbox.git",
    "directory": "packages/cloudflare"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "bun run build",
    "test": "bun test test"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.10.2",
    "@sandbox-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.1",
    "typescript": "^5.9.3"
  }
}
