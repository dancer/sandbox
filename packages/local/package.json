{
  "name": "@sandbox-sdk/local",
  "version": "0.0.0",
  "description": "Local sandbox adapter for Sandbox SDK",
  "keywords": [
    "agent",
    "local",
    "sandbox",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/dancer/sandbox#readme",
  "bugs": {
    "url": "https://github.com/dancer/sandbox/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dancer/sandbox.git",
    "directory": "packages/local"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "bun run build",
    "test": "bun test test"
  },
  "dependencies": {
    "@sandbox-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
