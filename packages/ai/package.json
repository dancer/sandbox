{
  "name": "@sandbox-sdk/ai",
  "version": "0.0.0",
  "description": "Agent tool helpers for Sandbox SDK",
  "keywords": [
    "agent",
    "ai",
    "sandbox",
    "sdk",
    "typescript"
  ],
  "homepage": "https://sandbox-sdk.sh",
  "bugs": {
    "url": "https://github.com/dancer/sandbox/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dancer/sandbox.git",
    "directory": "packages/ai"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./claude": {
      "types": "./dist/claude.d.ts",
      "default": "./dist/claude.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "default": "./dist/openai.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "bun run build",
    "test": "bun test test"
  },
  "dependencies": {
    "@sandbox-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@openai/agents": "^0.11.4",
    "@sandbox-sdk/local": "workspace:*",
    "ai": "^6.0.190",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@openai/agents": "^0.11.0",
    "ai": "^6.0.0 || ^7.0.0-0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
