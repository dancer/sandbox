{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["@cloudflare/workers-types"],
    "verbatimModuleSyntax": true
  },
  "include": ["*.ts"]
}
